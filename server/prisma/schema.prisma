datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Url {
  id          Int      @id @default(autoincrement())
  shortCode   String   @unique
  longUrl     String
  clicks      Int      @default(0)
  userId      String?
  createdAt   DateTime @default(now())
  expiresAt   DateTime?
  isActive    Boolean  @default(true)

  @@index([shortCode])
}
